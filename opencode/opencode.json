{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash": {
      "git *": "ask",
      "gcloud *": "ask",
      "tofu *": "ask",
    }
  },
  "model": "github-copilot/claude-sonnet-4.6",
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest", "--no-usage-statistics"],
      "enabled": true
    }
  }
}
